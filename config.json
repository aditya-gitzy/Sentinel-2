{
  "watch_directory": "~/Downloads",
  "settle_seconds": 3,
  "rules": {
    "CollegeDocs": {
      "extensions": [
        ".pdf",
        ".docx",
        ".txt",
        ".doc"
      ],
      "keywords": [
        "assign",
        "assignment",
        "ass",
        "project",
        "report"
      ]
    },
    "Images": {
      "extensions": [
        ".jpg",
        ".jpeg",
        ".png",
        ".gif",
        ".webp"
      ],
      "keywords": []
    },
    "GeneralDocs": {
      "extensions": [
        ".pdf",
        ".docx",
        ".doc",
        ".txt",
        ".xlsx",
        ".pptx"
      ],
      "keywords": []
    }
  },
  "destinations": {
    "CollegeDocs": "~/Documents/College_Assignments",
    "Images": "~/Pictures/Saved",
    "GeneralDocs": "~/Documents/General",
    "Others": "~/Documents/Unsorted"
  }
}